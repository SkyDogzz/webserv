{
	"servers": [
		{
			"listen": "8111",
			"server_name": "localhost",
			"error_pages": {
				"404": "/errors/404.html"
			},
			"locations": {
				"/": {
					"methods": ["GET"],
					"root": "./www",
					"index": "index.html",
					"autoindex": false
				},
				"/cgi-bin": {
					"methods": ["GET", "POST"],
					"cgi_path": "/usr/bin/python3",
					"cgi_ext": ".py",
					"upload_enable": true,
					"upload_store": "./www/uploads"
				}
			}
		}
	]
}
